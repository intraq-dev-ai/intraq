NODE_ENV=development
API_PORT=4100
WEB_ORIGIN=http://127.0.0.1:5173
VITE_API_BASE_URL=/api
INTRAQ_WEB_HOST=0.0.0.0
INTRAQ_WEB_PORT=5173

DATABASE_URL=postgresql://user:password@localhost:5432/intraq
AUTH_TOKEN_SECRET=replace-this-local-dev-secret-with-32-plus-random-chars

INTRAQ_SQL_QUERY_TIMEOUT_MS=15000
LIVE_SQL_QUERY_TIMEOUT_MS=15000
INTRAQ_SQL_ROUTE_TIMEOUT_MS=16000

# AI is bring-your-own-provider. Local/manual AI behavior tests must use Codex
# OAuth only; do not put OpenAI API keys in local developer env files.
AI_AGENT_PROVIDER=
CODEX_AGENT_ENABLED=
CODEX_HOME=
CODEX_AUTH_PATH=

# Optional SMTP for self-hosted dashboard delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
