# Runtime mode
NODE_ENV=development

# API server
API_HOST=127.0.0.1
API_PORT=4100
WEB_ORIGIN=http://127.0.0.1:5173

# Web dev server
VITE_API_BASE_URL=/api
INTRAQ_WEB_HOST=0.0.0.0
INTRAQ_WEB_PORT=5173

# Database and required runtime secret
DATABASE_URL=postgresql://user:password@localhost:5432/intraq
AUTH_TOKEN_SECRET=replace-this-local-dev-secret-with-32-plus-random-chars

# Optional secret-encryption keys. If omitted, AUTH_TOKEN_SECRET is used.
INTRAQ_SECRET_KEY=
DATA_SOURCE_CONFIG_ENCRYPTION_KEY=
SMTP_ENCRYPTION_KEY=

# Docker Compose host port. The container API still listens on 4100.
INTRAQ_PORT=4100

# Optional API/runtime behavior
DASHBOARD_PERSISTENCE=prisma
SERVE_WEB_FROM_API=true
WEB_DIST_DIR=
API_ENFORCE_AUTH=
API_ACCEPT_AUTH_COOKIE=
SEED_DEMO_RUNTIME=true
ENABLE_RUNTIME_DIAGNOSTICS=false

# SQL and live-query safeguards
INTRAQ_SQL_QUERY_TIMEOUT_MS=15000
LIVE_SQL_QUERY_TIMEOUT_MS=15000
INTRAQ_SQL_ROUTE_TIMEOUT_MS=16000
INTRAQ_LIVE_SQL_POOL_MAX=
INTRAQ_LIVE_SQL_CACHE_TTL_MS=
INTRAQ_LIVE_SQL_CACHE_MAX_ENTRIES=

# AI is bring-your-own-provider. Self-hosted operators can configure Codex
# OAuth, OpenAI, or Gemini through the admin UI or these environment variables.
# Contributors should avoid committing or sharing provider keys.
AI_AGENT_PROVIDER=
CODEX_AGENT_ENABLED=
CODEX_HOME=
CODEX_AUTH_PATH=
CODEX_MODEL=
CODEX_AGENT_TIMEOUT_MS=
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_REDIRECT_URI=http://localhost:1455/auth/callback
OPENAI_OAUTH_AUTH_URL=
OPENAI_OAUTH_TOKEN_URL=
OPENAI_OAUTH_SCOPE=

# Optional self-hosted AI providers. Keep API keys out of commits, screenshots,
# support issues, and shared environments.
OPENAI_AGENT_ENABLED=
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_API_ENDPOINT=
OPENAI_AGENT_TIMEOUT_MS=
GEMINI_AGENT_ENABLED=
GEMINI_API_KEY=
GOOGLE_GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_API_ENDPOINT=
GEMINI_AGENT_TIMEOUT_MS=

# Optional SMTP for self-hosted dashboard delivery
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_REPLY_TO=
SMTP_BCC=
SMTP_SECURE=
SMTP_DRY_RUN=

# Optional public API/embed controls
PUBLIC_API_CLIENT_ID=
PUBLIC_API_CLIENT_SECRET=
PUBLIC_API_CLIENT_TENANT_ID=
PUBLIC_API_CLIENT_USER_ID=
EMBED_EXTERNAL_ALLOWED_DASHBOARDS=
